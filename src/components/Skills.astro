---
---
<section id="skills" class="skills-section container animate-fade-up">
  <div class="section-header">
    <h2>Tech <span class="text-gradient">Stack</span></h2>
    <p>Teknologi dan alat yang sering saya gunakan.</p>
  </div>
  
  <div class="skills-grid">
    <div class="skill-item glass">
      <div class="icon">🚀</div>
      <h3>Astro</h3>
      <p>Web framework super cepat</p>
    </div>
    <div class="skill-item glass">
      <div class="icon">🐹</div>
      <h3>Go (Golang)</h3>
      <p>Bahasa backend tangguh & cepat</p>
    </div>
    <div class="skill-item glass">
      <div class="icon">🐳</div>
      <h3>Docker</h3>
      <p>Containerisasi & Deployment</p>
    </div>
    <div class="skill-item glass">
      <div class="icon">⚡</div>
      <h3>JavaScript</h3>
      <p>Interaktivitas & Logika Web</p>
    </div>
    <div class="skill-item glass">
      <div class="icon">📦</div>
      <h3>Node.js</h3>
      <p>Backend & Tooling</p>
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 100px 24px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .section-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
  }

  .skill-item {
    padding: 32px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .skill-item:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px -20px var(--accent-neon);
    border-color: var(--accent-neon);
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .skill-item h3 {
    margin-bottom: 8px;
    font-size: 1.3rem;
  }

  .skill-item p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
