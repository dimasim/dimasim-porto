---
---
<section class="hero container">
  <div class="hero-content animate-fade-up">
    <p class="greeting">👋 Halo, Saya</p>
    <h1 class="title">Seorang <span class="text-gradient">IT Enthusiast</span> & Developer.</h1>
    <p class="subtitle">Membangun pengalaman web yang keren, interaktif, dan modern. Saya fokus pada frontend development dan desain UI/UX yang premium.</p>
    <div class="hero-actions">
      <a href="#projects" class="btn-primary">Lihat Karya Saya</a>
      <a href="#contact" class="btn-outline">Hubungi Saya</a>
    </div>
  </div>
  
  <div class="hero-visual animate-fade-up" style="animation-delay: 0.2s;">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    
    <div class="profile-container">
      <div class="profile-frame">
        <!-- Taruh foto Anda di folder public dengan nama /images/profile.jpg -->
        <img src="/images/profile.jpg" alt="Dimas Irsyad Maulana" class="profile-img" onerror="this.src='https://api.dicebear.com/7.x/bottts/svg?seed=dimasim'" />
      </div>

      <div class="glass glass-card">
        <code>
          const dev = {<br>
          &nbsp;&nbsp;name: "Dimas Irsyad Maulana",<br>
          &nbsp;&nbsp;skills: ["Go", "Docker", "C++", "PHP", "Astro"],<br>
          &nbsp;&nbsp;passion: "Backend Dev & System Engineering"<br>
          };
        </code>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 100px;
    gap: 40px;
  }

  .hero-content {
    flex: 1;
    max-width: 600px;
  }

  .greeting {
    font-size: 1.2rem;
    color: var(--accent-neon);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .title {
    font-size: 4rem;
    margin-bottom: 24px;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .hero-visual {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400px;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
  }

  .orb-1 {
    width: 300px;
    height: 300px;
    background: var(--accent-purple);
    top: 0;
    right: 10%;
    opacity: 0.5;
    animation: float 6s ease-in-out infinite;
  }

  .orb-2 {
    width: 250px;
    height: 250px;
    background: var(--accent-neon);
    bottom: 0;
    left: 10%;
    opacity: 0.5;
    animation: float 8s ease-in-out infinite reverse;
  }

  .glass-card {
    padding: 32px;
    font-family: monospace;
    font-size: 1.1rem;
    color: var(--accent-neon);
    transform: rotate(-2deg);
    transition: transform 0.3s ease;
  }

  .glass-card:hover {
    transform: rotate(0deg) scale(1.05);
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0px); }
  }

  .profile-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    z-index: 1;
  }

  .profile-frame {
    width: 280px;
    height: 360px;
    border-radius: 24px;
    padding: 4px;
    background: linear-gradient(135deg, var(--accent-neon), var(--accent-purple));
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.4);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .profile-frame:hover {
    transform: scale(1.03) rotate(2deg);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
    background: var(--bg-dark);
  }

  @media (max-width: 968px) {
    .hero {
      flex-direction: column;
      text-align: center;
      padding-top: 150px;
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .title {
      font-size: 3rem;
    }
  }
</style>
